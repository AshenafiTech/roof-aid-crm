# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Telnyx
# Required for all telnyx work (M4):
TELNYX_API_KEY=                       # V2 API key (Telnyx portal → API Keys)
TELNYX_PUBLIC_KEY=                    # Webhook signature verification, Ed25519 base64 (Account → Public Key)
TELNYX_MESSAGING_PROFILE_ID=          # Messaging → Profiles → "Roof-Aid"; auto-attached to purchased numbers
TELNYX_VOICE_APP_ID=                  # Voice → Call Control Applications → "Roof-Aid"; auto-attached to purchased numbers
# (legacy alias for TELNYX_VOICE_APP_ID — keep until all callers are migrated)
TELNYX_APP_ID=
# Required for stage 2 (WebRTC softphone):
TELNYX_CONNECTION_ID=                 # SIP/WebRTC connection used to issue per-rep credentials
# Dev-only fallback for system-test traffic that has no tenant context.
# In production, every outbound call/SMS uses a number from tenant_phone_numbers.
TELNYX_DEFAULT_NUMBER=                # E.164, e.g. +14795550123

# SendGrid
SENDGRID_API_KEY=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
